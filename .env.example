# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Database ────────────────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/manga_tracker?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_database_password_here

# ── Twilio SMS ───────────────────────────────────────────────────────────────
# Find these at console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ── Default user ─────────────────────────────────────────────────────────────
# Auto-subscribed to every manga that is added
DEFAULT_USER_NAME=YourName
DEFAULT_USER_PHONE=+1xxxxxxxxxx

# ── Authentication ───────────────────────────────────────────────────────────
# HTTP Basic credentials. REQUIRED in production (set SPRING_PROFILES_ACTIVE=prod
# so the app fails to start if these are missing). Local dev has fallback values.
APP_AUTH_USERNAME=dev
APP_AUTH_PASSWORD=local-dev-only

# ── Optional overrides ───────────────────────────────────────────────────────
# PORT=8080
# CORS_ALLOWED_ORIGINS=http://localhost:4200
# SPRING_PROFILES_ACTIVE=prod
